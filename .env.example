# ===== chill-assistant 環境変数テンプレート =====
# このファイルをコピーして `.env` として使ってね
#   cp .env.example .env
# 値の上書きは必要なものだけでOK (コメントアウトされてる項目は Settings の既定値を使う)

# ---- 基本設定 ----
DEBUG_MODE=false

# ---- パス設定 (通常は変更不要、backend/data/ 配下に自動作成される) ----
# STATIC_DIR=
# LOGS_DIR=
# TEMP_DIR=
# SHARED_DIR=
# DIALOGUES_DIR=
# IMAGES_DIR=

# ---- VOICEVOX ----
VOICEVOX_HOST=http://127.0.0.1:50021
VOICEVOX_SPEAKER=0
# 自分の環境に合わせて書き換えてね (<USER> を自分のユーザー名に)
VOICEVOX_ENGINE_PATH=C:\Users\<USER>\AppData\Local\Programs\VOICEVOX\vv-engine\run.exe
VOICE_COOLDOWN=1.5

# ---- Watcher (Step 2) ----
# 差分検知しきい値 (0〜255、ゲーム調整時は下げる余地あり)
WATCHER_SCREEN_DIFF_THRESHOLD=12.0
# 周期 (秒)
WATCHER_ACTIVE_INTERVAL_SEC=3.0
WATCHER_IDLE_INTERVAL_SEC=10.0
WATCHER_FUNYA_INTERVAL_SEC=30.0
WATCHER_WINDOW_POLL_INTERVAL_SEC=2.0
# キュー / 画像サイズ
WATCHER_QUEUE_MAX_SIZE=64
WATCHER_DIFF_RESIZE_W=240
WATCHER_DIFF_RESIZE_H=135
# 強制発火 - ゲーム中のメニュー開閉などを拾うため (PR #5)
# しきい値の N 倍超 + クールダウン経過で animating 中でも再 enqueue
WATCHER_STRONG_DIFF_MULTIPLIER=2.0
WATCHER_REENQUEUE_COOLDOWN_SEC=5.0
# 診断ログ (skip も INFO に昇格、ゲーム調整時のみ true にする)
WATCHER_VERBOSE_LOG=false

# ---- プリセット参考: ゲーム (7DTD など) 用 ----
# 7DTD 実機計測で発火間隔 ~10秒、enqueue_strong_during_anim が主役。
# Step 3 の LLM レイテンシが見えたらクールダウン 5.0 に戻すのが安全。
#   WATCHER_SCREEN_DIFF_THRESHOLD=6.0
#   WATCHER_STRONG_DIFF_MULTIPLIER=1.5
#   WATCHER_REENQUEUE_COOLDOWN_SEC=3.0
#   WATCHER_VERBOSE_LOG=true

# ---- Companion (Step 3) — LM Studio 経由 Vision LLM ----
# LM Studio (http://localhost:1234) を起動してモデルをロードしておくこと
COMPANION_ENABLED=true
COMPANION_MODEL=qwen3-vl-8b-instruct
COMPANION_BASE_URL=http://localhost:1234/v1
COMPANION_API_KEY=lm-studio
COMPANION_MAX_TOKENS=80
COMPANION_TEMPERATURE=0.7
COMPANION_TIMEOUT_SEC=60.0
# watcher event 駆動発話の最小間隔 (秒)。LLM レイテンシ 5〜8s を考慮
COMPANION_RATE_LIMIT_SEC=60.0
COMPANION_JPEG_QUALITY=70
# 起動時に 1x1 ダミー画像で warm-up を走らせる (初回 KV cache 温め)
COMPANION_WARMUP_ON_LOAD=true

# ---- 機能トグル (環境変数ベース、settings.py 外) ----
# 1 / true / yes で無効化
DISABLE_FUNYA_WATCHER=1
DISABLE_SCREEN_WATCHER=0
DISABLE_COMPANION=0
